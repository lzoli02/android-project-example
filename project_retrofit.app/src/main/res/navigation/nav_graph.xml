<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/nav_graph"
  app:startDestination="@id/loginFragment">

  <fragment
    android:id="@+id/loginFragment"
    android:name="com.zoltanlorinczi.project_retrofit.fragment.LoginFragment"
    android:label="LoginFragment"
    tools:layout="@layout/fragment_login">

    <action
      android:id="@+id/action_loginFragment_to_listFragment"
      app:destination="@id/listFragment"/>

    <action
      android:id="@+id/action_loginFragment_to_second_activity"
      app:destination="@id/secondActivity"/>
  </fragment>

  <fragment
    android:id="@+id/listFragment"
    android:name="com.zoltanlorinczi.project_retrofit.fragment.ListFragment"
    android:label="ListFragment"
    tools:layout="@layout/fragment_list">
  </fragment>

  <activity
    android:id="@+id/secondActivity"
    android:name="com.zoltanlorinczi.project_retrofit.SecondActivity"
    android:label="activity_second"
    tools:layout="@layout/activity_second" />
</navigation>